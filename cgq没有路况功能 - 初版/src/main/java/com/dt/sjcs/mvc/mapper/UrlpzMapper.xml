<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dt.sjcs.mvc.dao.UrlpzDao">

	<select id="findByPage" resultType="com.dt.sjcs.mvc.pojo.Urlpz">
		select * from sj_urlpz
	</select>

	<select id="selectByPrimaryKey" parameterType="string" resultType="com.dt.sjcs.mvc.pojo.Urlpz">
        select * from sj_urlpz where id = #{id}
    </select>

	<insert id="insert" parameterType="com.dt.sjcs.mvc.pojo.Urlpz">
    	insert into sj_urlpz (id,url,factoryCode,deviceClass,appId,secretKey,sbbh,zdbm,zdmc,dwid,dwmc,msg,bj,sfcs
    	)values(#{id},#{url},#{factoryCode},#{deviceClass},#{appId},#{secretKey},#{sbbh},#{zdbm},#{zdmc},#{dwid},#{dwmc},#{msg},#{bj},#{sfcs})
    </insert>

	<update id="update" parameterType="com.dt.sjcs.mvc.pojo.Urlpz">
    	update sj_urlpz set
    	url = #{url},factoryCode = #{factoryCode},deviceClass = #{deviceClass},appId = #{appId},secretKey = #{secretKey},
    	sbbh = #{sbbh},zdbm = #{zdbm},zdmc = #{zdmc},dwid = #{dwid},dwmc = #{dwmc},msg = #{msg},bj = #{bj},sfcs = #{sfcs}
    	where id = #{id}
    </update>

	<delete id="delete">
    	delete from sj_urlpz where id = #{id}
    </delete>
	
	<select id="findList" resultType="com.dt.sjcs.mvc.pojo.Urlpz">
		select * from sj_urlpz where sfcs = '0'
	</select>

	<select id="findSbbh" resultType="java.lang.String">
		select sbbh from sj_urlpz where dwid = #{dwid} limit 1
	</select>

</mapper>