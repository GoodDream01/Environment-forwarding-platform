<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dt.cgq.mvc.dao.AreaDao">

	<select id="findByPage" resultType="com.dt.cgq.mvc.pojo.Area">
		select * from t_area
	</select>
	
	<select id="selectAll" resultType="com.dt.cgq.mvc.pojo.Area">
		select * from t_area
		<where> 
			<if test="param.qyid!=null and param.qyid!=''">
	            and id in (SELECT id FROM (SELECT t1.*, IF (FIND_IN_SET(pid, @pids) <![CDATA[ > ]]> 0, @pids := CONCAT(@pids, ',', id), 0) AS ischild FROM
	            (SELECT * FROM t_area t ORDER BY pid, id) t1,(SELECT @pids := #{param.qyid}) t2) t3 WHERE (ischild != 0 OR id = #{param.qyid}))
	        </if>
		</where>
	</select>
	
 	<select id="selectByPrimaryKey" parameterType="string" resultType="com.dt.cgq.mvc.pojo.Area">
        select * from t_area where id = #{id}
    </select>

	<insert id="insert" parameterType="com.dt.cgq.mvc.pojo.Area">
    	insert into t_area (id,pid,name,bz)values(#{id},#{pid},#{name},#{bz}) 
    </insert>
    
    <update id="update" parameterType="com.dt.cgq.mvc.pojo.Area">
    	update t_area set pid = #{pid},name = #{name},bz = #{bz} where id = #{id}
    </update>
    
    <delete id="delete">
    	delete from t_area where id = #{id}
    </delete>
    
</mapper>