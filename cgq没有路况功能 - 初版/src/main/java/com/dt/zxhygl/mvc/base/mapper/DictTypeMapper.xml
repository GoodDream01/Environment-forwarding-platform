<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.dt.zxhygl.mvc.base.dao.IDictTypeDao">
    
    <!--根据主键查询一条用户数据-->
    <select id="selectByPrimaryKey" parameterType="string" resultType="DictType">
        select * from hy_dict_type where id=#{id}
    </select>
    
    <select id="selectAll" resultType="DictType">
        select * from hy_dict_type where status='0' order by code
    </select>


</mapper>